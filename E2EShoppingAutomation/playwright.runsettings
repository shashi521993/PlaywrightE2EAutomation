<?xml version="1.0" encoding="utf-8"?>
<RunSettings>
  <RunConfiguration>
    <MaxCpuCount>1</MaxCpuCount>
    <EnvironmentVariables>
      <HEADED>1</HEADED>
    </EnvironmentVariables>
  </RunConfiguration>

  <Playwright>
    <BrowserName>chromium</BrowserName> <!-- firefox / webkit -->
    <LaunchOptions>
      <Headless>false</Headless>
      <SlowMo>500</SlowMo>
	</LaunchOptions>
  </Playwright>
</RunSettings>

