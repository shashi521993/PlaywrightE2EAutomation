<?xml version="1.0" encoding="utf-8"?>
<RunSettings>
	<NUnit>
		<NumberOfTestWorkers>3</NumberOfTestWorkers>
	</NUnit>

  <Playwright>
    <BrowserName>chromium</BrowserName> <!-- firefox / webkit -->
    <LaunchOptions>
      <Headless>false</Headless>
      <SlowMo>500</SlowMo>
	</LaunchOptions>
  </Playwright>
</RunSettings>

